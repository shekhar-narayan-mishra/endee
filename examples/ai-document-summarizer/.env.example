# ─── LLM Provider Configuration ───────────────────────────────────────────────
# Choose "gemini" (default) or "openai"
LLM_PROVIDER=gemini

# Google Gemini API Key  (https://aistudio.google.com/app/apikey)
GEMINI_API_KEY=your_gemini_api_key_here

# OpenAI API Key  (optional – only needed if LLM_PROVIDER=openai)
OPENAI_API_KEY=your_openai_api_key_here

# ─── Endee Vector Database ────────────────────────────────────────────────────
# URL where Endee server is running (Docker: port 8080 by default)
ENDEE_HOST=http://localhost:8080

# Optional: Endee auth token (only if you started Endee with -e NDD_AUTH_TOKEN)
# ENDEE_AUTH_TOKEN=your_endee_token_here

# ─── Server Configuration ─────────────────────────────────────────────────────
API_PORT=8000        # FastAPI backend port
GRADIO_PORT=7860     # Gradio frontend port

# API URL that the Gradio frontend connects to
API_BASE_URL=http://localhost:8000
